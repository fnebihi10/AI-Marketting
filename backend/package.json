{
  "name": "backend",
  "version": "2.0.0",
  "description": "AI Marketing Studio MVP backend",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "ai",
    "marketing",
    "video",
    "bullmq",
    "express"
  ],
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.887.0",
    "@supabase/supabase-js": "^2.57.2",
    "bullmq": "^5.58.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.8.2",
    "mime-types": "^2.1.35",
    "mongoose": "^8.18.0",
    "multer": "^2.0.2",
    "openai": "^6.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
